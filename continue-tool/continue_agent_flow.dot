digraph ContinueAgentFlow {
  rankdir=TB;
  bgcolor="white";
  node [shape=box, style="rounded,filled", color="#1f2937", fillcolor="#f9fafb", fontname="Helvetica", fontsize=11];
  edge [color="#374151", arrowsize=0.7, penwidth=1.1];

  start [label="Start cn"];
  parse [label="Parse args"];
  mode [shape=diamond, label="Headless (-p)?", fillcolor="#fff7ed", color="#9a3412"];
  init_h [label="Initialize services (headless)"];
  init_t [label="Initialize services (TUI)"];
  input_h [label="Get one-shot prompt"];
  input_t [label="Get user input (chat loop)"];

  core [label="Core agent loop\n(system prompt + tools + LLM stream)", fillcolor="#eff6ff", color="#1d4ed8"];
  toolsq [shape=diamond, label="Tool calls?", fillcolor="#eff6ff", color="#1d4ed8"];
  run_tools [label="Execute tools"];
  add_results [label="Add tool results to history"];
  response [label="Assistant response ready"];

  out_h [label="Print output + exit", fillcolor="#ecfdf5", color="#166534"];
  out_t [label="Render in TUI + wait next turn", fillcolor="#ecfdf5", color="#166534"];

  start -> parse -> mode;
  mode -> init_h [label="Yes"];
  mode -> init_t [label="No"];

  init_h -> input_h -> core;
  init_t -> input_t -> core;

  core -> toolsq;
  toolsq -> response [label="No"];
  toolsq -> run_tools [label="Yes"];
  run_tools -> add_results -> core;

  response -> out_h;
  response -> out_t;
  out_t -> input_t [label="next message"];
}
